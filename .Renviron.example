# Google Gemini API Key for AI-powered improvement suggestions
# Get your key at: https://makersuite.google.com/app/apikey
#
# Setup instructions:
# 1. Copy this file to .Renviron (in the project root directory)
# 2. Replace 'your_api_key_here' with your actual Google API key
# 3. Restart your R session for changes to take effect
# 4. Verify setup: Sys.getenv("GOOGLE_API_KEY")
#
# Note: .Renviron is gitignored to keep your API key secure
GOOGLE_API_KEY=your_api_key_here

# ----------------------------------------------------------------------
# Analytics pipeline (valgfri — kun relevant hvis du koerer med sync)
# ----------------------------------------------------------------------
# Fine-grained GitHub PAT med contents:write paa bispcharts-analytics-data
# Bruges af session$onSessionEnded() til at pushe shinylogs-aggregat.
# Hvis ikke sat, preserveres data kun lokalt i logs/.
GITHUB_PAT=ghp_your_fine_grained_token_here
PIN_REPO_URL=https://github.com/YOUR_ORG/YOUR_ANALYTICS_REPO.git
# PIN_REPO_BRANCH=main  # valgfri, default: main
