#!/bin/bash
# ==============================================================================
# pre-push git hook for biSPCharts
# ==============================================================================
# §3.1.1 af harden-test-suite-regression-gate openspec change.
#
# Formål: Forhindre at rød test-suite eller lintr-fejl pushes til remote.
#
# Installation:
#   Rscript dev/install_git_hooks.R
#
# Bypass (brug sparsomt):
#   git push --no-verify     # Git-native bypass
#   SKIP_PREPUSH=1 git push  # Environment-variabel bypass
#
# Hurtig vs fuld tilstand (§3.1.5):
#   PREPUSH_MODE=fast git push  # Kun lintr + unit-tests (~2 min)
#   PREPUSH_MODE=full git push  # Alt inkl. performance + integration (default)
#
# Exit koder:
#   0 = alle checks bestået, push tilladt
#   1 = lintr eller test fejl, push blokeret
#   2 = Rscript ikke tilgængelig (skippes med advarsel)
# ==============================================================================

set -euo pipefail

# Bypass via env-variabel (nyttigt når #239-paraply blokerer)
if [ "${SKIP_PREPUSH:-0}" = "1" ]; then
  echo "⚠ SKIP_PREPUSH=1 — springer pre-push checks over"
  exit 0
fi

MODE="${PREPUSH_MODE:-full}"
START_TIME=$(date +%s)

# --- Tjek at Rscript er tilgængelig ---
# Exit 0 (ikke 2) så push tillades på maskiner uden R. Git fortolker
# enhver non-zero exit som push-blokering, og intentionen er "skip med
# advarsel". Fix baseret på review-finding (§post-review).
if ! command -v Rscript &>/dev/null; then
  echo "⚠ Rscript ikke fundet i PATH — pre-push springes over"
  echo "  Installér R eller opdatér PATH for at aktivere pre-push-checks"
  exit 0
fi

# --- Repo root (hook kan køres fra andet cwd) ---
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

echo "════════════════════════════════════════════════════════════════"
echo " biSPCharts pre-push checks (mode=$MODE)"
echo "════════════════════════════════════════════════════════════════"

# --- Step 1: lintr ---
echo ""
echo "[1/2] Kører lintr::lint_package() ..."
LINT_OUTPUT=$(Rscript -e '
  suppressPackageStartupMessages(library(lintr))
  lints <- lintr::lint_package()
  errors <- Filter(function(x) x$type == "error", lints)
  if (length(errors) > 0) {
    print(errors)
    cat(sprintf("\n✗ %d lintr ERROR(s) fundet — push blokeret\n", length(errors)))
    quit(status = 1)
  }
  warnings <- Filter(function(x) x$type == "warning", lints)
  if (length(warnings) > 0) {
    cat(sprintf("⚠ %d lintr warnings (ikke blokerende)\n", length(warnings)))
  }
  cat("✓ lintr OK\n")
' 2>&1) || {
  echo "$LINT_OUTPUT"
  echo ""
  echo "✗ lintr fejlede — push blokeret"
  echo "  Fix lintr-fejl eller brug 'git push --no-verify' til bypass"
  exit 1
}
echo "$LINT_OUTPUT"

# --- Step 2: testthat ---
# SECURITY (§post-review fix): Brug heredoc med single-quoted delimiter
# ('REOF') så shell IKKE interpolerer R-koden. Tidligere design brugte
# `Rscript -e "$TEST_CMD"` med double-quoting som tillod shell-expansion
# af metacharacters i env-variabler → potentiel kode-injection.
echo ""
if [ "$MODE" = "fast" ]; then
  echo "[2/2] Kører unit-tests (hurtig tilstand) ..."
  Rscript - <<'REOF'
suppressPackageStartupMessages({ library(devtools); library(testthat) })
res <- devtools::test_active_file(
  "tests/testthat/helper-bootstrap.R",
  reporter = testthat::SummaryReporter$new()
)
# Hurtig: kun udvalgte små testfiler
quick_files <- c(
  "test-event-context-handlers.R",
  "test-helper-mocks-contracts.R",
  "test-negative-assertions-phase2-5.R"
)
for (f in quick_files) {
  p <- file.path("tests/testthat", f)
  if (file.exists(p)) devtools::test_active_file(p, reporter = testthat::SummaryReporter$new())
}
cat("✓ Hurtig pre-push bestået\n")
REOF
  TEST_EXIT=$?
else
  echo "[2/2] Kører fuld testthat-suite (kan tage 5-10 min) ..."
  Rscript - <<'REOF'
suppressPackageStartupMessages({ library(devtools); library(testthat) })
res <- devtools::test(stop_on_failure = FALSE, reporter = testthat::SummaryReporter$new())
df <- as.data.frame(res)
fails <- sum(df$failed)
errs <- sum(df$error == TRUE)
cat(sprintf("\nResultat: %d pass, %d fail, %d err, %d skip\n",
  sum(df$passed), fails, errs, sum(df$skipped)))
if (fails > 0 || errs > 0) {
  cat("\n✗ Test-suite er rød — push blokeret\n")
  cat("  Fix testene eller brug SKIP_PREPUSH=1 git push til bypass\n")
  cat("  (kun anbefalet når #239-paraply blokerer — se CLAUDE.md §6)\n")
  quit(status = 1)
}
cat("✓ Alle tests grønne\n")
REOF
  TEST_EXIT=$?
fi

if [ "$TEST_EXIT" -ne 0 ]; then
  echo ""
  echo "✗ Tests fejlede — push blokeret"
  exit 1
fi

# --- Timing + done ---
END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo ""
echo "════════════════════════════════════════════════════════════════"
echo " ✓ Pre-push OK — varighed: ${DURATION}s (mode=$MODE)"
echo "════════════════════════════════════════════════════════════════"

# Advar hvis varighed >5 min (§3.1.5)
if [ "$DURATION" -gt 300 ]; then
  echo ""
  echo "⚠ Pre-push tog ${DURATION}s (>5 min target)"
  echo "  Overvej PREPUSH_MODE=fast for hurtigere iteration"
fi

exit 0
