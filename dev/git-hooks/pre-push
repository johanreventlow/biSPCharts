#!/bin/bash
# ==============================================================================
# pre-push git hook for biSPCharts
# ==============================================================================
# §3.1.1 af harden-test-suite-regression-gate openspec change.
#
# Formål: Forhindre at lintr-fejl, invalid test-manifest eller røde
# hurtige regressionstests pushes til remote. Tunge browser-/visual-tests er
# opt-in, fordi de er miljøfølsomme på lokale udviklermaskiner.
#
# Installation:
#   Rscript dev/install_git_hooks.R
#
# Bypass (brug sparsomt):
#   git push --no-verify          # Git-native bypass (alt)
#   SKIP_PREPUSH=1 git push       # Bypass test/lintr checks
#   SKIP_BRANCH_CHECK=1 git push  # Bypass branch-check (master)
#
# Hurtig vs fuld tilstand (§3.1.5):
#   git push                    # fast default: lintr + manifest + små tests
#   PREPUSH_MODE=fast git push  # samme som default
#   PREPUSH_MODE=full git push  # hele testthat-suiten; shinytest2 stadig opt-in
#
# Exit koder:
#   0 = alle checks bestået, push tilladt
#   1 = branch-check, lintr eller test fejl, push blokeret
#   2 = Rscript ikke tilgængelig (skippes med advarsel)
# ==============================================================================

set -euo pipefail

# --- Step 0: Block direkte push til master ---
# Laes stdin (git giver refs som: <local-ref> <local-sha> <remote-ref> <remote-sha>)
# og blokerer hvis nogen line peger paa refs/heads/master.
# Kan bypasses med SKIP_BRANCH_CHECK=1 (fx til emergency hotfix).
PUSH_REFS=$(cat || true)
if [ "${SKIP_BRANCH_CHECK:-0}" != "1" ]; then
  if echo "$PUSH_REFS" | awk '{print $3}' | grep -qx "refs/heads/master"; then
    echo ""
    echo "✗ Direkte push til master er blokeret"
    echo ""
    echo "  Brug PR-flow via GitHub: feature → develop → master"
    echo ""
    echo "  Bypass (undtagelsestilfaelde):"
    echo "    SKIP_BRANCH_CHECK=1 git push"
    echo "    git push --no-verify"
    echo ""
    exit 1
  fi
fi

# Bypass via env-variabel (nyttigt når #239-paraply blokerer)
if [ "${SKIP_PREPUSH:-0}" = "1" ]; then
  echo "⚠ SKIP_PREPUSH=1 — springer pre-push checks over"
  exit 0
fi

MODE="${PREPUSH_MODE:-fast}"
START_TIME=$(date +%s)

# --- Tjek at Rscript er tilgængelig ---
# Exit 0 (ikke 2) så push tillades på maskiner uden R. Git fortolker
# enhver non-zero exit som push-blokering, og intentionen er "skip med
# advarsel". Fix baseret på review-finding (§post-review).
if ! command -v Rscript &>/dev/null; then
  echo "⚠ Rscript ikke fundet i PATH — pre-push springes over"
  echo "  Installér R eller opdatér PATH for at aktivere pre-push-checks"
  exit 0
fi

# --- Repo root (hook kan køres fra andet cwd) ---
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

echo "════════════════════════════════════════════════════════════════"
echo " biSPCharts pre-push checks (mode=$MODE)"
echo "════════════════════════════════════════════════════════════════"

# --- Step 1: lintr ---
echo ""
echo "[1/3] Kører lintr::lint_package() ..."
LINT_OUTPUT=$(Rscript -e '
  suppressPackageStartupMessages(library(lintr))
  lints <- lintr::lint_package()
  errors <- Filter(function(x) x$type == "error", lints)
  if (length(errors) > 0) {
    print(errors)
    cat(sprintf("\n✗ %d lintr ERROR(s) fundet — push blokeret\n", length(errors)))
    quit(status = 1)
  }
  warnings <- Filter(function(x) x$type == "warning", lints)
  if (length(warnings) > 0) {
    cat(sprintf("⚠ %d lintr warnings (ikke blokerende)\n", length(warnings)))
  }
  cat("✓ lintr OK\n")
' 2>&1) || {
  echo "$LINT_OUTPUT"
  echo ""
  echo "✗ lintr fejlede — push blokeret"
  echo "  Fix lintr-fejl eller brug 'git push --no-verify' til bypass"
  exit 1
}
echo "$LINT_OUTPUT"

# --- Step 2: manifest validation ---
echo ""
echo "[2/3] Validerer test-classification manifest ..."
Rscript dev/classify_tests.R --validate || {
  echo ""
  echo "✗ Test-classification manifest er invalid — push blokeret"
  echo "  Kør: Rscript dev/classify_tests.R --validate"
  exit 1
}

# --- Step 3: testthat ---
# SECURITY (§post-review fix): Brug heredoc med single-quoted delimiter
# ('REOF') så shell IKKE interpolerer R-koden. Tidligere design brugte
# `Rscript -e "$TEST_CMD"` med double-quoting som tillod shell-expansion
# af metacharacters i env-variabler → potentiel kode-injection.
echo ""
if [ "$MODE" = "fast" ]; then
  echo "[3/3] Kører hurtige regressionstests ..."
  Rscript - <<'REOF'
suppressPackageStartupMessages({ library(devtools); library(testthat) })
run_checked_file <- function(path) {
  res <- testthat::test_file(path, reporter = testthat::SummaryReporter$new())
  df <- as.data.frame(res)
  fails <- sum(df$failed)
  errs <- sum(df$error == TRUE)
  if (fails > 0 || errs > 0) {
    cat(sprintf("\n✗ %s fejlede: %d fail, %d err\n", path, fails, errs))
    quit(status = 1)
  }
}

source("tests/testthat/helper-bootstrap.R", chdir = TRUE)

quick_files <- c(
  "test-audit-classifier.R",
  "test-event-context-handlers.R",
  "test-helper-mocks-contracts.R",
  "test-negative-assertions-phase2-5.R",
  "test-utils-export-analysis-metadata.R",
  "test-utils_logging.R"
)
for (f in quick_files) {
  p <- file.path("tests/testthat", f)
  if (file.exists(p)) run_checked_file(p)
}
cat("✓ Hurtig pre-push bestået\n")
REOF
  TEST_EXIT=$?
else
  echo "[3/4] Kører fuld testthat-suite (kan tage 5-10 min) ..."
  Rscript - <<'REOF'
suppressPackageStartupMessages({ library(devtools); library(testthat) })
res <- devtools::test(stop_on_failure = FALSE, reporter = testthat::SummaryReporter$new())
df <- as.data.frame(res)
fails <- sum(df$failed)
errs <- sum(df$error == TRUE)
cat(sprintf("\nResultat: %d pass, %d fail, %d err, %d skip\n",
  sum(df$passed), fails, errs, sum(df$skipped)))
if (fails > 0 || errs > 0) {
  cat("\n✗ Test-suite er rød — push blokeret\n")
  cat("  Fix testene eller brug SKIP_PREPUSH=1 git push til bypass\n")
  cat("  (kun anbefalet når #239-paraply blokerer — se CLAUDE.md §6)\n")
  quit(status = 1)
}
cat("✓ Alle tests grønne\n")
REOF
  TEST_EXIT=$?

  # --- Step 4 (full only): R CMD check --as-cran ---
  echo ""
  echo "[4/4] Kører R CMD check --as-cran (ingen tests/manual/vignettes) ..."
  Rscript -e '
    result <- rcmdcheck::rcmdcheck(
      args = c("--as-cran", "--no-tests", "--no-manual", "--no-vignettes", "--no-build-vignettes"),
      quiet = TRUE
    )
    warnings <- result$warnings
    if (length(warnings) > 0) {
      cat(sprintf("✗ R CMD check: %d WARNING(s) fundet:\n", length(warnings)))
      for (w in warnings) cat(sprintf("  - %s\n", trimws(w)))
      cat("\n  Fix warnings eller brug SKIP_PREPUSH=1 git push til bypass\n")
      quit(status = 1)
    }
    cat(sprintf("✓ R CMD check OK (%d NOTEs ignoreres)\n", length(result$notes)))
  ' || {
    echo ""
    echo "✗ R CMD check fejlede — push blokeret"
    exit 1
  }
fi

if [ "$TEST_EXIT" -ne 0 ]; then
  echo ""
  echo "✗ Tests fejlede — push blokeret"
  exit 1
fi

# --- Timing + done ---
END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo ""
echo "════════════════════════════════════════════════════════════════"
echo " ✓ Pre-push OK — varighed: ${DURATION}s (mode=$MODE)"
echo "════════════════════════════════════════════════════════════════"

# Advar hvis varighed >5 min (§3.1.5)
if [ "$DURATION" -gt 300 ]; then
  echo ""
  echo "⚠ Pre-push tog ${DURATION}s (>5 min target)"
  echo "  Overvej PREPUSH_MODE=fast for hurtigere iteration"
fi

exit 0
